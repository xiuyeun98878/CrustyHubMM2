-- Animate loading
task.spawn(function()
	for i = 1, 100 do
		local progress = i / 100
		
		fill.Size = UDim2.new(progress,0,1,0)
		percent.Text = i .. "%"
		
		local stageIndex = math.clamp(math.ceil((i / 100) * #stages),1,#stages)
		status.Text = stages[stageIndex]
		
		task.wait(0.2) -- 100 * 0.2 = 20 seconds
	end
end)

-- Wait full duration
