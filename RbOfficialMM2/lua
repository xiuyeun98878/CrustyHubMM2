-- Fake Loading Animation
task.spawn(function()
	local index = 1

	while true do
		status.Text = messages[index]

		index += 1
		if index > #messages then
			index = 1
		end

		task.wait(1.2)
	end
end)

-- Floating Window Animation
task.spawn(function()
	while true do
		local up = TweenService:Create(
			frame,
			TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{Position = frame.Position - UDim2.new(0,0,0,6)}
		)

		local down = TweenService:Create(
			frame,
			TweenInfo.new(1.5, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut),
			{Position = frame.Position}
		)

		up:Play()
		up.Completed:Wait()

		down:Play()
		down.Completed:Wait()
	end
end)

-- Pulsing Glow
task.spawn(function()
	while true do
		local tween1 = TweenService:Create(
			stroke,
			TweenInfo.new(1),
			{Thickness = 6}
		)

		local tween2 = TweenService:Create(
			stroke,
			TweenInfo.new(1),
			{Thickness = 3}
		)

		tween1:Play()
		tween1.Completed:Wait()

		tween2:Play()
		tween2.Completed:Wait()
	end
end)

